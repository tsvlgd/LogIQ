.vscode/
.idea/
*.swp
.DS_Store

# ---------------------------
# Logs & local artifacts
# ---------------------------
*.log
*.sqlite3

# ---------------------------
# Docker files themselves (optional)
# ---------------------------
docker-compose*
compose*.yml
